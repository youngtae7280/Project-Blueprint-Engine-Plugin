{
  "name": "devview",
  "private": true,
  "version": "0.2.0-alpha",
  "description": "DevView Codex plugin workflow for Maintainability Graph context, View Trees, Context Packs, evidence, and guarded graph updates.",
  "type": "module",
  "bin": {
    "devview": "./dist/cli/index.js"
  },
  "files": [
    ".codex-plugin/plugin.json",
    "AGENTS.md",
    "CHANGELOG.md",
    "README.md",
    "RELEASE.md",
    "docs/index.md",
    "docs/install.md",
    "docs/cli-reference.md",
    "docs/troubleshooting.md",
    "docs/concept/README.md",
    "docs/concept/devview-terminology.md",
    "skills/**"
  ],
  "scripts": {
    "clean:dist": "node scripts/clean-dist.js",
    "build:cli": "npm run clean:dist && tsc -p tsconfig.cli.json",
    "devview": "node dist/cli/index.js",
    "validate:devview": "npm run build:cli && node dist/cli/index.js validate && npm run check:release-surface",
    "check:release-surface": "node scripts/check-devview-release-surface.js --pack-dry-run",
    "validate:devview:legacy-tree": "node scripts/validate-devview-legacy-tree-system.js",
    "validate:devview:legacy-operation-chain": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/invoke-devview-legacy-v0.ps1 -Command operation-chain",
    "validate:devview:legacy-dogfood": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/invoke-devview-legacy-v0.ps1 -Command evaluate-dogfood",
    "test:graph-operation:flow": "npm run build:cli && node scripts/graph-operation-flow-smoke.js",
    "typecheck": "tsc -b",
    "test": "vitest run",
    "test:examples": "npm run build:cli && node scripts/test-examples.js",
    "test:read-model:e2e": "npm run build:cli && node scripts/read-model-e2e-smoke.js",
    "devview:runtime:smoke": "node scripts/devview-runtime-timing-smoke.mjs",
    "check:graph-source:candidate-b": "npm run build:cli && node dist/cli/index.js graph read-model report-health --json && node scripts/read-model-e2e-smoke.js",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "build": "npm run validate:devview",
    "validate": "npm run validate:devview"
  },
  "devDependencies": {
    "@eslint/js": "9.27.0",
    "@types/node": "20.17.10",
    "ajv": "^8.17.1",
    "eslint": "9.27.0",
    "globals": "15.14.0",
    "prettier": "^3.5.3",
    "typescript": "5.7.2",
    "typescript-eslint": "8.18.2",
    "vitest": "3.2.6"
  },
  "dependencies": {
    "openai": "^6.45.0"
  }
}
