{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local/project-blueprint-engine/work-tree.schema.json",
  "title": "PBE Work Tree",
  "type": "object",
  "required": ["version", "rootNodeId", "nodes"],
  "properties": {
    "version": { "type": "string" },
    "rootNodeId": { "type": "string" },
    "nodes": { "type": "array", "items": { "$ref": "#/$defs/node" } },
    "edges": { "type": "array", "items": { "type": "object" } }
  },
  "$defs": {
    "node": {
      "type": "object",
      "required": ["id", "type", "title", "status", "derivedFromProductNodeIds", "derivedFromProjectNodeIds", "scopeClass"],
      "properties": {
        "id": { "type": "string" },
        "type": { "enum": ["foundation_task", "feature_task", "ui_task", "api_task", "domain_task", "integration_task", "verification_support_task", "documentation_task", "review_task"] },
        "title": { "type": "string" },
        "status": { "enum": ["ready", "in_progress", "implemented", "blocked", "stale", "revised", "deferred", "out_of_scope"] },
        "derivedFromProductNodeIds": { "type": "array", "items": { "type": "string" } },
        "derivedFromProjectNodeIds": { "type": "array", "items": { "type": "string" } },
        "scopeClass": { "enum": ["selected", "foundation", "deferred", "blocked", "out_of_scope"] },
        "expectedFiles": { "type": "array", "items": { "type": "string" } },
        "expectedSharedFiles": { "type": "array", "items": { "type": "string" } },
        "forbiddenFiles": { "type": "array", "items": { "type": "string" } },
        "unknownFileTouchRisk": { "type": "boolean" },
        "dependencies": { "type": "array", "items": { "type": "string" } },
        "satisfiesAcceptanceCriteriaIds": { "type": "array", "items": { "type": "string" } },
        "acceptanceCriteriaNotLinkedReason": { "type": "string" },
        "doneCriteria": { "type": "array", "items": { "type": "string" } },
        "validationHints": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
