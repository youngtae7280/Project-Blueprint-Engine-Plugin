{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local/project-blueprint-engine/execution-manifest.schema.json",
  "title": "ACEP Execution Manifest",
  "type": "object",
  "required": ["schemaVersion", "autonomyLevel", "tasks", "stopConditions"],
  "properties": {
    "schemaVersion": { "type": "integer", "minimum": 1 },
    "autonomyLevel": { "type": "string", "enum": ["autonomous_until_stop"] },
    "executionStrategy": {
      "type": "string",
      "enum": ["staged_parallel", "sequential"]
    },
    "parallelPolicy": {
      "type": "object",
      "properties": {
        "default": { "type": "string", "enum": ["sequential"] },
        "maxInitialParallelGroupSize": { "type": "integer", "minimum": 1 },
        "maxMatureParallelGroupSize": { "type": "integer", "minimum": 1 },
        "moreThanMaxRequiresHumanApproval": { "type": "boolean" }
      },
      "additionalProperties": true
    },
    "deliveryStatus": {
      "type": "string",
      "enum": [
        "implemented",
        "verified",
        "submitted_for_review",
        "revision_requested",
        "revision_in_progress",
        "revision_verified"
      ]
    },
    "sourceBlueprintFiles": {
      "type": "array",
      "items": { "type": "string" }
    },
    "contractFiles": {
      "type": "object",
      "properties": {
        "traceabilityMatrix": { "type": "string" },
        "uiUxSpec": { "type": "string" },
        "uiUxPreview": { "type": "string" },
        "uiUxConfirmation": { "type": "string" },
        "operatingLoop": { "type": "string" },
        "uiUxEvidenceChecklist": { "type": "string" },
        "finalCoverageCheck": { "type": "string" },
        "finalReportTemplate": { "type": "string" },
        "executionStrategy": { "type": "string" },
        "sourceOfTruthMatrix": { "type": "string" },
        "foundationContract": { "type": "string" },
        "parallelSafetyContract": { "type": "string" }
      },
      "additionalProperties": true
    },
    "operatingLoop": { "type": "string" },
    "phases": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "mode"],
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "mode": { "type": "string", "enum": ["sequential", "parallel", "review_only"] },
          "tasks": { "type": "array", "items": { "type": "string" } },
          "parallelGroups": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "id",
                "tasks",
                "integrationTask",
                "integrationEvidenceRequired",
                "groupCannotCompleteWithoutIntegrationPass",
                "conflictRisk",
                "requiredCompletedBeforeStart"
              ],
              "properties": {
                "id": { "type": "string" },
                "tasks": {
                  "type": "array",
                  "minItems": 1,
                  "items": { "type": "string" },
                  "uniqueItems": true
                },
                "integrationTask": { "type": "string" },
                "integrationEvidenceRequired": { "type": "boolean" },
                "groupCannotCompleteWithoutIntegrationPass": { "type": "boolean" },
                "status": {
                  "type": "string",
                  "enum": [
                    "not_started",
                    "running",
                    "integration_pending",
                    "integration_passed",
                    "integration_failed",
                    "downgraded_to_sequential",
                    "blocked"
                  ]
                },
                "conflictRisk": { "type": "string", "enum": ["low", "medium", "high"] },
                "requiredCompletedBeforeStart": {
                  "type": "array",
                  "items": { "type": "string" }
                },
                "forbiddenChanges": {
                  "type": "array",
                  "items": { "type": "string" }
                }
              },
              "additionalProperties": true
            }
          }
        },
        "additionalProperties": true
      }
    },
    "tasks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "requirementIds", "evidenceRequired"],
        "anyOf": [
          { "required": ["taskCard"] },
          { "required": ["file"] }
        ],
        "oneOf": [
          { "required": ["verificationIds"] },
          { "required": ["verificationExplanation"] }
        ],
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "file": { "type": "string" },
          "taskCard": { "type": "string" },
          "dependsOn": { "type": "array", "items": { "type": "string" } },
          "phase": { "type": "string" },
          "scopeClass": {
            "type": "string",
            "enum": ["selected", "foundation", "deferred", "blocked", "out_of_scope"]
          },
          "workGraphNodeIds": { "type": "array", "items": { "type": "string" } },
          "executionMode": {
            "type": "string",
            "enum": ["sequential", "parallel_group", "integration", "review_only"]
          },
          "parallelGroup": { "type": ["string", "null"] },
          "canRunInParallelWith": { "type": "array", "items": { "type": "string" } },
          "mustRunAfter": { "type": "array", "items": { "type": "string" } },
          "mustRunBefore": { "type": "array", "items": { "type": "string" } },
          "conflictRisk": { "type": "string", "enum": ["low", "medium", "high"] },
          "expectedFiles": { "type": "array", "items": { "type": "string" } },
          "expectedSharedFiles": { "type": "array", "items": { "type": "string" } },
          "forbiddenFiles": { "type": "array", "items": { "type": "string" } },
          "forbiddenChanges": { "type": "array", "items": { "type": "string" } },
          "integrationRequired": { "type": "boolean" },
          "integrationTask": { "type": ["string", "null"] },
          "dependencyResolved": { "type": "boolean" },
          "writeSetKnown": { "type": "boolean" },
          "rollbackPathAvailable": { "type": "boolean" },
          "nodeId": { "type": "string" },
          "requirementIds": { "type": "array", "items": { "type": "string" } },
          "verificationIds": { "type": "array", "items": { "type": "string" } },
          "verificationExplanation": { "type": "string" },
          "uiUxIds": { "type": "array", "items": { "type": "string" } },
          "uiImpact": {
            "type": "string",
            "enum": ["none", "indirect", "direct"]
          },
          "uiUxConfirmationRequired": { "type": "boolean" },
          "uiUxConfirmationId": { "type": "string" },
          "uiUxReason": { "type": "string" },
          "evidenceRequired": { "type": "array", "items": { "type": "string" } },
          "focusedValidation": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": true
      }
    },
    "validation": { "type": "object" },
    "review": {
      "type": "object",
      "properties": {
        "resultReviewFolder": { "type": "string" },
        "acceptedStatusPolicy": { "type": "string", "enum": ["user_only"] },
        "codexFinalStatus": { "type": "string", "enum": ["submitted_for_review"] }
      },
      "additionalProperties": true
    },
    "stopConditions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "finalReportTemplate": { "type": "string" }
  },
  "additionalProperties": true
}
