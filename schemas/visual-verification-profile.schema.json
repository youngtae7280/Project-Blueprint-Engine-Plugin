{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local/devview/visual-verification-profile.schema.json",
  "title": "DevView Visual Verification Profile",
  "type": "object",
  "required": ["version", "profiles"],
  "properties": {
    "version": { "type": "string" },
    "schemaVersion": { "type": "string" },
    "artifactType": { "const": "visual_verification_profile" },
    "status": { "enum": ["draft", "proposed", "confirmed", "blocked"] },
    "visualContractRef": { "type": "string" },
    "designTokensRef": { "type": "string" },
    "componentContractRef": { "type": "string" },
    "surfaceInventoryRef": { "type": "string" },
    "contractChecks": {
      "type": "array",
      "items": { "$ref": "#/$defs/contractCheck" }
    },
    "blockingIssues": { "type": "array", "items": { "type": "object" } },
    "waivers": { "type": "array", "items": { "type": "object" } },
    "profiles": {
      "type": "array",
      "items": { "$ref": "#/$defs/profile" }
    }
  },
  "$defs": {
    "profile": {
      "type": "object",
      "required": ["id", "surfaceId", "applicability", "checks"],
      "properties": {
        "id": { "type": "string" },
        "surfaceId": { "type": "string" },
        "title": { "type": "string" },
        "applicability": { "enum": ["not_required", "recommended", "required"] },
        "productNodeIds": { "type": "array", "items": { "type": "string" } },
        "projectNodeIds": { "type": "array", "items": { "type": "string" } },
        "workNodeIds": { "type": "array", "items": { "type": "string" } },
        "testNodeIds": { "type": "array", "items": { "type": "string" } },
        "evidenceNodeIds": { "type": "array", "items": { "type": "string" } },
        "checks": {
          "type": "array",
          "items": { "$ref": "#/$defs/check" }
        },
        "notRunnableReason": { "type": "string" }
      },
      "additionalProperties": true
    },
    "check": {
      "type": "object",
      "required": ["id", "type", "status", "evidenceRequired"],
      "properties": {
        "id": { "type": "string" },
        "type": {
          "enum": [
            "screenshot_review",
            "popup_visual_review",
            "runtime_coordinate_check",
            "resize_dpi_review",
            "clipped_control_audit",
            "accessibility_check",
            "manual_visual_review"
          ]
        },
        "status": { "enum": ["not_planned", "planned", "passed", "failed", "blocked", "not_runnable"] },
        "evidenceRequired": { "type": "array", "items": { "type": "string" } },
        "evidenceNodeIds": { "type": "array", "items": { "type": "string" } },
        "reason": { "type": "string" }
      },
      "additionalProperties": true
    },
    "contractCheck": {
      "type": "object",
      "required": ["checkId", "description", "required", "status"],
      "properties": {
        "checkId": { "type": "string" },
        "description": { "type": "string" },
        "required": { "type": "boolean" },
        "status": { "enum": ["pending", "passed", "failed", "blocked", "not_required", "waived"] },
        "evidenceRefs": { "type": "array", "items": { "type": "string" } },
        "reason": { "type": "string" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
