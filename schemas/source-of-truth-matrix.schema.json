{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local/devview/source-of-truth-matrix.schema.json",
  "title": "DevView Source of Truth Matrix",
  "type": "object",
  "required": ["schemaVersion", "artifacts"],
  "properties": {
    "schemaVersion": { "type": "integer", "minimum": 1 },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["artifact", "sourceOfTruthFor", "derivedFrom", "mustNotOwn"],
        "properties": {
          "artifact": { "type": "string" },
          "sourceOfTruthFor": { "type": "array", "items": { "type": "string" } },
          "derivedFrom": { "type": "array", "items": { "type": "string" } },
          "mustNotOwn": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
