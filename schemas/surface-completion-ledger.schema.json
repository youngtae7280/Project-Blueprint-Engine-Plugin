{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local/project-blueprint-engine/surface-completion-ledger.schema.json",
  "title": "PBE Surface Completion Ledger",
  "type": "object",
  "required": ["version", "surfaces"],
  "properties": {
    "version": { "type": "string" },
    "profileApplicability": {
      "type": "array",
      "items": {
        "enum": ["legacy_migration", "parity_critical", "ui_heavy", "hardware_dependent", "subdialog_parity"]
      }
    },
    "surfaces": {
      "type": "array",
      "items": { "$ref": "#/$defs/surface" }
    }
  },
  "$defs": {
    "surface": {
      "type": "object",
      "required": ["id", "title", "scopeClass", "completionLayer", "productNodeIds", "workNodeIds", "testNodeIds"],
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "surfaceKind": {
          "enum": ["screen", "dialog", "popup", "subdialog", "command", "workflow", "other"]
        },
        "parentSurfaceId": { "type": ["string", "null"] },
        "childSurfaceIds": { "type": "array", "items": { "type": "string" } },
        "opensDialog": { "type": "boolean" },
        "openedByCommandIds": { "type": "array", "items": { "type": "string" } },
        "hardwareGated": { "type": "boolean" },
        "scopeClass": { "enum": ["selected", "foundation", "deferred", "blocked", "out_of_scope"] },
        "completionLayer": {
          "enum": ["not_started", "technical_stable", "parity_reviewed", "product_accepted", "blocked"]
        },
        "parityClaim": {
          "enum": ["not_claimed", "inventory_ready", "parity_reviewed", "parity_gap_known", "not_applicable"]
        },
        "productNodeIds": { "type": "array", "items": { "type": "string" } },
        "projectNodeIds": { "type": "array", "items": { "type": "string" } },
        "workNodeIds": { "type": "array", "items": { "type": "string" } },
        "testNodeIds": { "type": "array", "items": { "type": "string" } },
        "evidenceNodeIds": { "type": "array", "items": { "type": "string" } },
        "legacyInventoryIds": { "type": "array", "items": { "type": "string" } },
        "visualProfileIds": { "type": "array", "items": { "type": "string" } },
        "hardwareReadinessIds": { "type": "array", "items": { "type": "string" } },
        "acceptanceBranchIds": { "type": "array", "items": { "type": "string" } },
        "items": {
          "type": "array",
          "items": { "$ref": "#/$defs/completionItem" }
        },
        "subdialogAudit": {
          "type": "object",
          "properties": {
            "required": { "type": "boolean" },
            "status": {
              "enum": ["not_required", "pending_inventory", "inventory_ready", "verified", "gap_known", "blocked"]
            },
            "legacyDialogIds": { "type": "array", "items": { "type": "string" } },
            "childSurfaceIds": { "type": "array", "items": { "type": "string" } },
            "legacyInventoryIds": { "type": "array", "items": { "type": "string" } },
            "testNodeIds": { "type": "array", "items": { "type": "string" } },
            "evidenceNodeIds": { "type": "array", "items": { "type": "string" } },
            "notCheckedIds": { "type": "array", "items": { "type": "string" } },
            "reason": { "type": "string" }
          },
          "additionalProperties": true
        },
        "notChecked": {
          "type": "array",
          "items": { "$ref": "#/$defs/notCheckedItem" }
        },
        "deferredParityDebt": {
          "type": "array",
          "items": { "type": "string" }
        },
        "notes": { "type": "string" }
      },
      "additionalProperties": true
    },
    "completionItem": {
      "type": "object",
      "required": ["id", "label", "status"],
      "properties": {
        "id": { "type": "string" },
        "label": { "type": "string" },
        "itemKind": {
          "enum": ["command", "dialog_surface", "control", "event_handler", "workflow_behavior", "mock_check", "hardware_action", "state", "other"]
        },
        "status": {
          "enum": [
            "implemented",
            "missing",
            "deferred",
            "blocked",
            "verification_pending",
            "out_of_scope",
            "command_mapped",
            "dialog_surface_complete",
            "workflow_behavior_complete",
            "mock_verified",
            "hardware_user_testable",
            "hardware_certification_pending",
            "not_checked"
          ]
        },
        "hardwareGated": { "type": "boolean" },
        "substituteEvidenceType": {
          "enum": ["mock_backed_ui", "fake_read_result", "ui_automation_hardware_disabled", "manual_not_verified", "not_required"]
        },
        "productNodeIds": { "type": "array", "items": { "type": "string" } },
        "workNodeIds": { "type": "array", "items": { "type": "string" } },
        "testNodeIds": { "type": "array", "items": { "type": "string" } },
        "evidenceNodeIds": { "type": "array", "items": { "type": "string" } },
        "reason": { "type": "string" }
      },
      "additionalProperties": true
    },
    "notCheckedItem": {
      "type": "object",
      "required": ["id", "itemType", "label", "reason", "blocksCompletion"],
      "properties": {
        "id": { "type": "string" },
        "itemType": {
          "enum": ["dialog", "subdialog", "control", "event_handler", "hardware_action", "state", "workflow", "other"]
        },
        "label": { "type": "string" },
        "reason": { "type": "string" },
        "blocksCompletion": { "type": "boolean" },
        "requiredFollowUp": { "type": "string" },
        "testNodeIds": { "type": "array", "items": { "type": "string" } },
        "evidenceNodeIds": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
