{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local/devview/revision-manifest.schema.json",
  "title": "Revision Manifest",
  "type": "object",
  "required": ["schemaVersion", "revisionId", "sourceFeedbackItems", "tasks"],
  "properties": {
    "schemaVersion": { "type": "integer", "minimum": 1 },
    "revisionId": { "type": "string" },
    "sourceFeedbackItems": { "type": "array", "items": { "type": "string" } },
    "sourceChangeIds": { "type": "array", "items": { "type": "string" } },
    "impactIds": { "type": "array", "items": { "type": "string" } },
    "status": {
      "type": "string",
      "enum": ["revision_requested", "revision_in_progress", "revision_verified", "submitted_for_review", "blocked"]
    },
    "affectedRequirementIds": { "type": "array", "items": { "type": "string" } },
    "affectedTaskIds": { "type": "array", "items": { "type": "string" } },
    "affectedUiUxIds": { "type": "array", "items": { "type": "string" } },
    "affectedVerificationIds": { "type": "array", "items": { "type": "string" } },
    "affectedProductNodeIds": { "type": "array", "items": { "type": "string" } },
    "affectedProjectNodeIds": { "type": "array", "items": { "type": "string" } },
    "affectedWorkNodeIds": { "type": "array", "items": { "type": "string" } },
    "affectedTestNodeIds": { "type": "array", "items": { "type": "string" } },
    "affectedEvidenceNodeIds": { "type": "array", "items": { "type": "string" } },
    "affectedCycleIds": { "type": "array", "items": { "type": "string" } },
    "reopenedNodeIds": { "type": "array", "items": { "type": "string" } },
    "staleEvidenceNodeIds": { "type": "array", "items": { "type": "string" } },
    "nodeStateTransitions": { "type": "array", "items": { "type": "object" } },
    "allowedFiles": { "type": "array", "items": { "type": "string" } },
    "forbiddenFiles": { "type": "array", "items": { "type": "string" } },
    "mustNotTouch": { "type": "array", "items": { "type": "string" } },
    "maxChangeIntent": {
      "type": "string",
      "enum": ["bounded_fix_only", "bounded_test_only", "bounded_ui_fix", "scope_expansion_requires_user"]
    },
    "nonScope": { "type": "array", "items": { "type": "string" } },
    "tasks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "file", "feedbackItemIds", "evidenceRequired"],
        "properties": {
          "id": { "type": "string" },
          "file": { "type": "string" },
          "title": { "type": "string" },
          "feedbackItemIds": { "type": "array", "items": { "type": "string" } },
          "affectedRequirementIds": { "type": "array", "items": { "type": "string" } },
          "affectedTaskIds": { "type": "array", "items": { "type": "string" } },
          "affectedUiUxIds": { "type": "array", "items": { "type": "string" } },
          "affectedVerificationIds": { "type": "array", "items": { "type": "string" } },
          "affectedProductNodeIds": { "type": "array", "items": { "type": "string" } },
          "affectedProjectNodeIds": { "type": "array", "items": { "type": "string" } },
          "affectedWorkNodeIds": { "type": "array", "items": { "type": "string" } },
          "affectedTestNodeIds": { "type": "array", "items": { "type": "string" } },
          "affectedEvidenceNodeIds": { "type": "array", "items": { "type": "string" } },
          "impactIds": { "type": "array", "items": { "type": "string" } },
          "allowedFiles": { "type": "array", "items": { "type": "string" } },
          "forbiddenFiles": { "type": "array", "items": { "type": "string" } },
          "evidenceRequired": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": true
      }
    },
    "regressionChecks": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": true
}
