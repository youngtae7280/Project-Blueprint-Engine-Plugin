{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local/devview/feedback-items.schema.json",
  "title": "Feedback Items",
  "type": "object",
  "required": ["schemaVersion", "items"],
  "properties": {
    "schemaVersion": { "type": "integer", "minimum": 1 },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "type", "rawFeedback", "summary", "status"],
        "properties": {
          "id": { "type": "string" },
          "type": {
            "type": "string",
            "enum": [
              "bug",
              "missing_requirement",
              "misinterpreted_requirement",
              "ux_mismatch",
              "visual_mismatch",
              "scope_gap",
              "performance_issue",
              "content_copy_issue",
              "accessibility_issue",
              "other"
            ]
          },
          "rawFeedback": { "type": "string" },
          "summary": { "type": "string" },
          "affectedRequirementIds": { "type": "array", "items": { "type": "string" } },
          "affectedTaskIds": { "type": "array", "items": { "type": "string" } },
          "affectedUiUxIds": { "type": "array", "items": { "type": "string" } },
          "affectedVerificationIds": { "type": "array", "items": { "type": "string" } },
          "affectedProductNodeIds": { "type": "array", "items": { "type": "string" } },
          "affectedProjectNodeIds": { "type": "array", "items": { "type": "string" } },
          "affectedWorkNodeIds": { "type": "array", "items": { "type": "string" } },
          "affectedTestNodeIds": { "type": "array", "items": { "type": "string" } },
          "affectedEvidenceNodeIds": { "type": "array", "items": { "type": "string" } },
          "affectedCycleIds": { "type": "array", "items": { "type": "string" } },
          "changeNodeIds": { "type": "array", "items": { "type": "string" } },
          "requiresChangeNode": { "type": "boolean" },
          "mappingExplanation": { "type": "string" },
          "severity": { "type": "string", "enum": ["low", "medium", "high", "blocker"] },
          "needsClarification": { "type": "boolean" },
          "clarificationQuestions": { "type": "array", "items": { "type": "string" } },
          "ambiguity": {
            "type": "object",
            "properties": {
              "status": { "enum": ["clear", "partial", "ambiguous"] },
              "missing": {
                "type": "array",
                "items": {
                  "enum": [
                    "target",
                    "target_detail",
                    "condition",
                    "expected_behavior",
                    "completion_criteria",
                    "exception_handling",
                    "verification_method"
                  ]
                }
              },
              "abstractTerms": { "type": "array", "items": { "type": "string" } },
              "requiresRevisionRpd": { "type": "boolean" }
            },
            "additionalProperties": true
          },
          "revisionRpd": {
            "type": "object",
            "properties": {
              "required": { "type": "boolean" },
              "status": { "enum": ["not_required", "required", "pending", "in_progress", "resolved", "blocked"] },
              "questionsAsked": { "type": "array", "items": { "type": "string" } },
              "resolvedAcceptanceCriteriaIds": { "type": "array", "items": { "type": "string" } }
            },
            "additionalProperties": true
          },
          "criteriaChanges": {
            "type": "object",
            "properties": {
              "addsAcceptanceCriteriaIds": { "type": "array", "items": { "type": "string" } },
              "modifiesAcceptanceCriteriaIds": { "type": "array", "items": { "type": "string" } },
              "invalidatesAcceptanceCriteriaIds": { "type": "array", "items": { "type": "string" } }
            },
            "additionalProperties": true
          },
          "desiredOutcome": { "type": "string" },
          "status": { "type": "string", "enum": ["open", "clarifying", "packed", "resolved", "deferred"] }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
