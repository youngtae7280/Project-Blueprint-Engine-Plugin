{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local/devview/evidence-tree.schema.json",
  "title": "DevView Evidence Tree",
  "type": "object",
  "required": ["version", "evidence"],
  "properties": {
    "version": { "type": "string" },
    "evidence": { "type": "array", "items": { "$ref": "#/$defs/evidence" } }
  },
  "$defs": {
    "evidence": {
      "type": "object",
      "required": ["id", "type", "status", "provesNodeIds"],
      "properties": {
        "id": { "type": "string" },
        "type": {
          "enum": [
            "test_output",
            "screenshot",
            "manual_note",
            "log",
            "diff_summary",
            "review_note",
            "not_runnable_explanation"
          ]
        },
        "status": {
          "enum": [
            "required",
            "attached",
            "current",
            "stale",
            "stale_evidence",
            "superseded",
            "invalidated",
            "obsolete",
            "rejected",
            "replaced",
            "not_available"
          ]
        },
        "path": { "type": "string" },
        "provesNodeIds": { "type": "array", "items": { "type": "string" } },
        "provesProductNodeIds": { "type": "array", "items": { "type": "string" } },
        "provesWorkNodeIds": { "type": "array", "items": { "type": "string" } },
        "provesTestNodeIds": { "type": "array", "items": { "type": "string" } },
        "linkedProductNodeIds": { "type": "array", "items": { "type": "string" } },
        "linkedWorkNodeIds": { "type": "array", "items": { "type": "string" } },
        "linkedTestNodeIds": { "type": "array", "items": { "type": "string" } },
        "productNodeIds": { "type": "array", "items": { "type": "string" } },
        "workNodeIds": { "type": "array", "items": { "type": "string" } },
        "testNodeIds": { "type": "array", "items": { "type": "string" } },
        "evidenceForTestNodeIds": { "type": "array", "items": { "type": "string" } },
        "evidenceForAcceptanceCriteriaIds": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" },
        "recordedAt": { "type": "string" },
        "timestamp": { "type": "string" },
        "verifiedAt": { "type": "string" },
        "supersedesEvidenceIds": { "type": "array", "items": { "type": "string" } },
        "supersededByEvidenceId": { "type": ["string", "null"] }
      }
    }
  }
}
