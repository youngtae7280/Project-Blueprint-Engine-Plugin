{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local/project-blueprint-engine/legacy-control-inventory.schema.json",
  "title": "PBE Legacy Control Inventory",
  "type": "object",
  "required": ["version", "inventories"],
  "properties": {
    "version": { "type": "string" },
    "inventories": {
      "type": "array",
      "items": { "$ref": "#/$defs/inventory" }
    }
  },
  "$defs": {
    "inventory": {
      "type": "object",
      "required": ["id", "surfaceId", "sourceKind", "claimStatus", "productNodeIds", "controls"],
      "properties": {
        "id": { "type": "string" },
        "surfaceId": { "type": "string" },
        "title": { "type": "string" },
        "sourceKind": {
          "enum": ["rc_dialog", "xaml", "html", "native_ui", "screenshot", "documentation", "manual_reference", "other"]
        },
        "sourcePaths": { "type": "array", "items": { "type": "string" } },
        "dialogResourceIds": { "type": "array", "items": { "type": "string" } },
        "claimStatus": {
          "enum": ["inventory_only", "gap_known", "parity_claimed", "not_applicable"]
        },
        "productNodeIds": { "type": "array", "items": { "type": "string" } },
        "projectNodeIds": { "type": "array", "items": { "type": "string" } },
        "workNodeIds": { "type": "array", "items": { "type": "string" } },
        "testNodeIds": { "type": "array", "items": { "type": "string" } },
        "evidenceNodeIds": { "type": "array", "items": { "type": "string" } },
        "controls": {
          "type": "array",
          "items": { "$ref": "#/$defs/control" }
        },
        "eventHandlers": {
          "type": "array",
          "items": { "$ref": "#/$defs/eventHandler" }
        },
        "childSurfaceIds": { "type": "array", "items": { "type": "string" } },
        "notes": { "type": "string" }
      },
      "additionalProperties": true
    },
    "control": {
      "type": "object",
      "required": ["id", "label", "legacyState", "currentStatus"],
      "properties": {
        "id": { "type": "string" },
        "label": { "type": "string" },
        "controlType": { "type": "string" },
        "legacyState": {
          "enum": ["visible_enabled", "visible_disabled", "hidden", "not_applicable"]
        },
        "currentStatus": {
          "enum": ["matched", "missing", "deferred", "blocked", "unverified", "not_applicable"]
        },
        "requiredForParity": { "type": "boolean" },
        "eventHandlerIds": { "type": "array", "items": { "type": "string" } },
        "childSurfaceId": { "type": "string" },
        "currentImplementationRef": { "type": "string" },
        "evidenceNodeIds": { "type": "array", "items": { "type": "string" } },
        "reason": { "type": "string" }
      },
      "additionalProperties": true
    },
    "eventHandler": {
      "type": "object",
      "required": ["id", "legacyHandler", "currentStatus"],
      "properties": {
        "id": { "type": "string" },
        "legacyHandler": { "type": "string" },
        "triggerControlId": { "type": "string" },
        "expectedBehavior": { "type": "string" },
        "requiredForParity": { "type": "boolean" },
        "currentStatus": {
          "enum": ["matched", "missing", "deferred", "blocked", "unverified", "not_applicable"]
        },
        "currentImplementationRef": { "type": "string" },
        "evidenceNodeIds": { "type": "array", "items": { "type": "string" } },
        "reason": { "type": "string" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
