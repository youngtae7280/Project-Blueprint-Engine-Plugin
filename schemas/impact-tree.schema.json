{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local/devview/impact-tree.schema.json",
  "title": "DevView Impact Tree",
  "type": "object",
  "required": ["version", "impacts"],
  "properties": {
    "version": { "type": "string" },
    "impacts": { "type": "array", "items": { "$ref": "#/$defs/impact" } }
  },
  "$defs": {
    "impact": {
      "type": "object",
      "required": ["id", "changeId", "affectedNodeId", "impactType", "requiredAction"],
      "properties": {
        "id": { "type": "string" },
        "changeNodeId": { "type": "string" },
        "changeId": { "type": "string" },
        "status": { "enum": ["proposed", "analyzed", "applied", "superseded"] },
        "affectedProductNodeIds": { "type": "array", "items": { "type": "string" } },
        "affectedWorkNodeIds": { "type": "array", "items": { "type": "string" } },
        "affectedTestNodeIds": { "type": "array", "items": { "type": "string" } },
        "affectedEvidenceNodeIds": { "type": "array", "items": { "type": "string" } },
        "affectedAcceptanceNodeIds": { "type": "array", "items": { "type": "string" } },
        "affectedNodeIds": { "type": "array", "items": { "type": "string" } },
        "affectedNodeId": { "type": "string" },
        "affectedAcceptanceCriteriaIds": { "type": "array", "items": { "type": "string" } },
        "impactType": {
          "enum": ["none", "stale", "invalidated", "reopened", "obsolete", "requires_retest", "requires_new_evidence"]
        },
        "requiredAction": {
          "enum": ["preserve", "defer", "fork", "reopen", "retest", "replace_evidence", "human_decision"]
        },
        "reason": { "type": "string" },
        "createdAt": { "type": "string" }
      }
    }
  }
}
