{
  "$id": "https://project-blueprint-engine.local/schemas/pbe/graph-update-proposal-v0.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "schemaVersion": 1,
  "artifactRole": "pbe-graph-update-proposal-schema-v0",
  "status": "draft-active",
  "purpose": "Proposal artifact derived from a graph delta before any graph-source mutation.",
  "requiredTopLevelFields": [
    "schemaVersion",
    "artifactRole",
    "status",
    "graphDeltaPath",
    "sourceRecordId",
    "proposedRecordState",
    "proposedNodeUpdates",
    "changedFiles",
    "edgeIntentSummary",
    "boundaries"
  ],
  "boundaryRequirements": {
    "mutatesGraphSource": false,
    "requiresReviewBeforeApply": true
  }
}
