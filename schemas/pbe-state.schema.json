{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local/project-blueprint-engine/pbe-state.schema.json",
  "title": "PBE State",
  "type": "object",
  "required": ["schemaVersion", "stage", "mode", "artifacts"],
  "properties": {
    "schemaVersion": { "type": "integer", "minimum": 1 },
    "projectId": { "type": "string" },
    "stage": {
      "type": "string",
      "enum": ["start", "rpd", "wpd", "vd", "execution_planning", "acep_ready", "acep_running", "complete", "blocked"]
    },
    "mode": {
      "type": "string",
      "enum": ["rpd_tree_walk", "wpd_generation", "vd_generation", "execution_planning", "acep_generation", "acep_execution"]
    },
    "currentNodeId": { "type": ["string", "null"] },
    "deliveryStatus": {
      "type": "string",
      "enum": [
        "implemented",
        "verified",
        "submitted_for_review",
        "revision_requested",
        "revision_in_progress",
        "revision_verified",
        "accepted"
      ]
    },
    "acceptance": {
      "type": "object",
      "required": ["setBy", "acceptedAt", "acceptanceSource"],
      "properties": {
        "setBy": { "type": "string", "enum": ["user"] },
        "acceptedAt": { "type": "string" },
        "acceptanceSource": {
          "type": "string",
          "enum": ["explicit_user_reply"]
        },
        "reviewGateId": { "type": "string" },
        "notes": { "type": "string" }
      },
      "additionalProperties": false
    },
    "createdAt": { "type": "string" },
    "updatedAt": { "type": "string" },
    "artifacts": { "type": "object" }
    ,
    "autoflow": { "$ref": "autoflow-state.schema.json" }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "deliveryStatus": { "const": "accepted" }
        },
        "required": ["deliveryStatus"]
      },
      "then": {
        "required": ["acceptance"],
        "properties": {
          "acceptance": {
            "required": ["setBy", "acceptedAt", "acceptanceSource"],
            "properties": {
              "setBy": { "const": "user" },
              "acceptanceSource": { "const": "explicit_user_reply" }
            }
          }
        }
      }
    }
  ],
  "additionalProperties": true
}
