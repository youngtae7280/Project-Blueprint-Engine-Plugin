  "clarificationTriggerPolicy": {
    "policyStatus": "boundary-preview-only",
    "triggerHandling": "stop-before-traversal-and-ask-structured-questions",
    "triggers": [
      {
        "triggerId": "low-confidence",
        "sourceFields": ["confidence.score", "confidence.band"],
        "condition": "confidence band is low or confidence is below validation threshold",
        "result": "clarification-required"
      },
      {
        "triggerId": "unknown-request-type",
        "sourceFields": ["requestTypeCandidate"],
        "condition": "requestTypeCandidate is unknown",
        "result": "clarification-required"
      },
      {
        "triggerId": "missing-target-record-or-component",
        "sourceFields": ["targetRecordIdCandidate", "targetComponentCandidate"],
        "condition": "target record or component candidate is missing or unresolved",
        "result": "clarification-required"
      },
      {
        "triggerId": "ambiguous-allowed-scope",
        "sourceFields": ["allowedScopeIntentCandidate"],
        "condition": "allowed scope intent cannot be mapped to bounded source or evidence/report scope",
        "result": "clarification-required"
      },
      {
        "triggerId": "ambiguous-forbidden-scope",
        "sourceFields": ["forbiddenScopeIntentCandidate"],
        "condition": "forbidden scope is absent, broad, or conflicts with runtime-evidence-only safety boundaries",
        "result": "clarification-required"
      },
      {
        "triggerId": "missing-evidence-requirement",
        "sourceFields": ["requiredEvidenceIntentCandidate"],
        "condition": "required evidence intent is missing or cannot be expressed as reviewable evidence/report context",
        "result": "clarification-required"
      },
      {
        "triggerId": "intent-source-authority-conflict",
        "sourceFields": ["intentSummaryCandidate", "targetRecordIdCandidate", "targetComponentCandidate"],
        "condition": "user intent conflicts with graph/read-model source authority or cannot be resolved against it",
        "result": "human-review-required"
      },
      {
        "triggerId": "production-source-edit-ambiguity",
        "sourceFields": ["allowedScopeIntentCandidate", "forbiddenScopeIntentCandidate"],
        "condition": "request may allow production source edits or does not clearly forbid them for runtime-evidence-only flow",
        "result": "clarification-required"
      },
      {
        "triggerId": "implicit-approval-apply-or-enforcement",
        "sourceFields": ["requestText", "intentSummaryCandidate"],
        "condition": "request asks or implies approval, graph apply, acceptance, runtime Evidence satisfaction, equivalence proof, scope enforcement, or CI enforcement",
        "result": "human-review-required"
      }
    ]
  },
  "interviewQuestionModel": {
    "modelStatus": "boundary-preview-only",
    "questionCountPerTurn": {
      "minimum": 1,
      "maximum": 3
    },
    "questionRequirements": [
      "Question must be short and mapped to one Request IR field.",
      "Question may offer mutually exclusive choices plus freeform clarification.",
      "Question must not record approval, acceptance, or a human decision.",
      "Question must not claim runtime Evidence satisfaction or graph-source authority.",
      "Question answers must create only a revised Request IR Candidate."
    ],
    "questionShape": {
      "questionId": "string",
      "mapsToRequestIrField": "requestTypeCandidate | targetRecordIdCandidate | targetComponentCandidate | allowedScopeIntentCandidate | forbiddenScopeIntentCandidate | requiredEvidenceIntentCandidate | riskIntentCandidate",
      "prompt": "short human-facing question",
      "choices": [
        {
          "label": "short option label",
          "candidateValue": "candidate value only",
          "authorityStatus": "answer-candidate-not-validated"
        }
      ],
      "freeformAllowed": true,
      "answerAuthorityStatus": "clarification-answer-not-approval"
    },
    "exampleQuestions": [
