      },
      {
        "questionId": "clarify-source-edit-boundary",
        "mapsToRequestIrField": "forbiddenScopeIntentCandidate",
        "prompt": "Should production source changes stay forbidden for this request?",
        "choices": [
          {
            "label": "Keep forbidden",
            "candidateValue": "production source changes forbidden",
            "authorityStatus": "answer-candidate-not-validated"
          },
          {
            "label": "Need source edits",
            "candidateValue": "production source edit requested",
            "authorityStatus": "answer-candidate-not-validated"
          }
        ],
        "freeformAllowed": true,
        "answerAuthorityStatus": "clarification-answer-not-approval"
      }
    ]
  },
