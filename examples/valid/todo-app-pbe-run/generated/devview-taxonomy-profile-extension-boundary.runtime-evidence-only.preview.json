{
  "schemaVersion": 1,
  "artifactRole": "devview-taxonomy-profile-extension-boundary-preview",
  "status": "devview-taxonomy-profile-extension-boundary-previewed",
  "boundaryName": "DevView Taxonomy Profile / Extension Boundary",
  "sourceProjectMemoryBoundary": "examples/valid/todo-app-pbe-run/generated/devview-project-memory-boundary.runtime-evidence-only.preview.json",
  "purpose": "Separate DevView core graph vocabulary from project-specific extension vocabulary so legacy or domain-specific kinds can be proposed without becoming traversal or contract authority before review.",
  "coreVocabularyPolicy": {
    "coreNodeKinds": ["requirement", "task", "change", "check", "evidence", "decision", "risk"],
    "coreEdgeKinds": ["depends-on", "touches", "preserves", "verifies", "reports-on", "blocks", "risks"],
    "authorityStatus": "existing-core-vocabulary-authority"
  },
  "extensionVocabularyPolicy": {
    "extensionAuthorityStatus": "proposal-only-not-approved",
    "extensionApplyImplemented": false,
    "extensionCanDriveTraversalBeforeApproval": false,
    "extensionCanDriveContractBeforeApproval": false,
    "extensionCanSatisfyEvidence": false,
    "extensionRequiresProjectMemoryRef": true,
    "extensionRequiresHumanReviewPacket": true
  },
  "exampleTaxonomyProfile": {
    "taxonomyProfileId": "legacy-retrofit-windowsutility-v0",
    "baseProfile": "legacy-retrofit",
    "profileAuthorityStatus": "preview-only-not-approved",
    "coreNodeKinds": ["requirement", "task", "change", "check", "evidence", "decision", "risk"],
    "extensionNodeKinds": [
      "legacy-utility-module",
      "execution-flow",
      "ui-layout-surface",
      "forbidden-flow-boundary",
      "integration-target",
      "native-interop",
      "hardware-boundary"
    ],
    "extensionEdgeKinds": [
      "legacy-module-scope",
      "execution-ownership",
      "ui-surface-ownership",
      "forbidden-flow-guard",
      "integration-target-scope"
    ],
    "extensionKindRationale": [
      {
        "kind": "legacy-utility-module",
        "reason": "Represent observed Utility_Windows utility directories without granting edit authority."
      },
      {
        "kind": "execution-flow",
        "reason": "Represent behavior-preservation flows such as read/write/save/load or hardware calls."
      },
      {
        "kind": "ui-layout-surface",
        "reason": "Represent bounded UI/resource surfaces such as CardPrinterConfig dialog layout."
      },
      {
        "kind": "forbidden-flow-boundary",
        "reason": "Represent flows that must stay out of scope unless a future reviewed direction change opens them."
      },
      {
        "kind": "integration-target",
        "reason": "Represent WindowsUtility migration or parity targets as context-only until work is approved."
      }
    ]
  },
  "extensionDeltaProposalModel": {
    "artifactRole": "future-taxonomy-extension-delta-proposal-preview",
    "proposalOnly": true,
    "requiredInputs": [
      "project-memory-candidate-or-approved-revision",
      "current-graph-source-vocabulary",
      "current-read-model-vocabulary",
      "direction-change-candidate-when-direction-changes"
    ],
    "requiredOutputs": [
      "missingKinds[]",
      "extraKinds[]",
      "deprecatedKinds[]",
      "viewTreeImpact[]",
      "traversalRisk[]",
      "humanReviewPacket"
    ],
    "applyImplemented": false
  },
  "extensionGapDetector": {
    "implemented": true,
    "command": "graph read-model report-project-memory-extension-gaps",
    "artifactRole": "devview-project-memory-extension-gap-report",
    "description": "Compare Project Memory required extension vocabulary against current graph-source/read-model vocabulary and report missing, extra, deprecated, or unapproved kinds.",
    "reportOnly": true,
    "automaticApplyAllowed": false
  },
  "safetyFlags": {
    "boundaryPreviewOnly": true,
    "extensionApplied": false,
    "approvedExtensionStateImplemented": false,
    "traversalPlannerBehaviorChanged": false,
    "contractAuthorityGranted": false,
    "graphSourceMutated": false,
    "graphDeltaApplied": false,
    "humanDecisionAutomated": false,
    "runtimeEvidenceSatisfied": false,
    "equivalenceProven": false,
    "scopeEnforced": false,
    "ciEnforcementEnabled": false
  },
  "nonAuthorityBoundary": "This boundary records extension vocabulary shape only. Project extension kinds remain proposal-only until a future human-reviewed project memory revision exists."
}
